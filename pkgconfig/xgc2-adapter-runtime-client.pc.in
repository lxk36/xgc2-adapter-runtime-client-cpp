prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: xgc2-adapter-runtime-client
Description: Generic XGC2 AdapterRuntimeLink C++ SDK and protocol bindings
Version: @PROJECT_VERSION@
Requires: protobuf grpc++
Libs: -L${libdir} -lxgc2_adapter_runtime_client -lxgc2_adapter_runtime_protocol
Cflags: -I${includedir}
