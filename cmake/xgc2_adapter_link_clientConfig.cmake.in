@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Protobuf REQUIRED)
find_dependency(PkgConfig REQUIRED)
find_dependency(Threads REQUIRED)
find_dependency(xgc2_protobuf REQUIRED CONFIG)
pkg_check_modules(GRPCPP REQUIRED IMPORTED_TARGET grpc++)

include("${CMAKE_CURRENT_LIST_DIR}/xgc2_adapter_link_clientTargets.cmake")

set(XGC2_ADAPTER_LINK_CLIENT_INCLUDE_DIRS
    "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")
set(XGC2_ADAPTER_LINK_CLIENT_LIBRARIES xgc2::adapter_link_client)

if(NOT TARGET xgc2::adapter_link_client OR
   NOT TARGET xgc2::adapter_link_protocol)
  set(xgc2_adapter_link_client_FOUND FALSE)
  set(xgc2_adapter_link_client_NOT_FOUND_MESSAGE
      "xgc2 adapter client targets were not imported")
  return()
endif()

check_required_components(xgc2_adapter_link_client)
